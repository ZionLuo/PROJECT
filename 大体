/* ============== 工具函数 ============== */

static void clear_stdin(void) {

    /* 只吃掉一个残留换行，避免误吞下一行输入 */

    int c = getchar();

    if (c != '\n' && c != EOF) ungetc(c, stdin);

}


static void pause_any_key(void) {

    printf("\n(按回车继续...)");

    fflush(stdout);

    clear_stdin();

}


static int pwd_strength_ok(const char* pwd) {

    if (!pwd || !pwd[0]) return 0;

    int hasLetter = 0, hasDigit = 0, hasSymbol = 0;

    for (int i = 0; pwd[i]; i++) {

        unsigned char c = (unsigned char)pwd[i];

        if (isalpha(c))      hasLetter = 1;

        else if (isdigit(c)) hasDigit = 1;

        else                 hasSymbol = 1;

    }

    /* 至少 2 类 */

    return (hasLetter + hasDigit + hasSymbol) >= 2;

}


/* 从 stdin 读一行（吃掉行尾换行） */

static void read_line(char* buf, int n) {

    if (!buf || n <= 0) return;

    if (!fgets(buf, n, stdin)) { buf[0] = '\0'; return; }

    int len = (int)strlen(buf);

    while (len > 0 && (buf[len - 1] == '\n' || buf[len - 1] == '\r')) {

        buf[--len] = '\0';

    }

}


/* 读一行非空内容，吞掉 scanf 残留的 \n */

static void read_token(char* buf, int n) {

    do {

        read_line(buf, n);

    } while (buf[0] == '\0' && !feof(stdin));

}


