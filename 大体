/* =========================================================

 *  管理员模块

 * ========================================================= */

void admin_create(struct admin** head) {

    FILE* fp = fopen("admin_text.text", "r");

    if (!fp) { *head = NULL; return; }

    struct admin* rear = NULL, * p;

    int n = 0;

    while (1) {

        p = (struct admin*)malloc(sizeof(struct admin));

        if (!p) { fclose(fp); exit(1); }

        if (fscanf(fp, "%31s %31s", p->username, p->password) != 2) {

            free(p); break;

        }

        p->next = NULL;

        if (!*head) *head = rear = p; else rear->next = p, rear = p;

        n++;

    }

    fclose(fp);

    if (n > 0) printf("[admin] 加载 %d 条管理员\n", n);

}


struct admin* admin_register(struct admin* h) {

    struct admin* p = (struct admin*)malloc(sizeof(struct admin));

    if (!p) return h;

    printf("管理员用户名 密码：");

    scanf("%31s %31s", p->username, p->password);

    if (!pwd_strength_ok(p->password)) {

        printf("密码强度不足（需包含字母/数字/符号中至少 2 类）\n");

        free(p); return h;

    }

    for (struct admin* q = h; q; q = q->next)

        if (strcmp(q->username, p->username) == 0) {

            printf("管理员 [%s] 已存在\n", p->username);

            free(p); return h;

        }

    p->next = NULL;

    if (!h) h = p;

    else { struct admin* r = h; while (r->next) r = r->next; r->next = p; }

    printf("管理员创建成功（退出时写入 admin_text.text）\n");

    return h;

}


struct admin* admin_login(struct admin* h, struct admin** c) {

    char u[NAME_LEN], pw[NAME_LEN];

    printf("管理员账号 密码："); scanf("%31s %31s", u, pw);

    struct admin* p = admin_search(h, u);

    if (!p) { printf("管理员不存在\n"); return h; }

    if (strcmp(p->password, pw) != 0) { printf("密码错误\n"); return h; }

    *c = p;

    printf("登录成功，欢迎 %s\n", u);

    return h;

}


void admin_change_password(struct admin* h, const char* u) {

    struct admin* p = admin_search(h, u); if (!p) return;

    char o[NAME_LEN], n[NAME_LEN];

    printf("旧密码 新密码："); scanf("%31s %31s", o, n);

    if (strcmp(p->password, o) != 0) { printf("旧密码错误\n"); return; }

    if (!pwd_strength_ok(n)) {

        printf("新密码强度不足\n"); return;

    }

    strcpy(p->password, n);

    printf("密码已更新\n");

}


struct admin* admin_delete(struct admin* h, const char* u) {

    struct admin* p = h, * pre = NULL;

    while (p) {

        if (strcmp(p->username, u) == 0) {

            if (!pre) h = p->next; else pre->next = p->next;

            free(p); printf("管理员 [%s] 已删除\n", u); return h;

        }

        pre = p; p = p->next;

    }

    printf("管理员不存在\n"); return h;

}


struct admin* admin_search(struct admin* h, const char* u) {

    for (struct admin* p = h; p; p = p->next)

        if (strcmp(p->username, u) == 0) return p;

    return NULL;

}


void admin_print(struct admin* h) {

    if (!h) { printf("无管理员\n"); return; }

    printf("管理员账号\t密码\n");

    for (struct admin* p = h; p; p = p->next)

        printf("%s\t%s\n", p->username, p->password);

}


void admin_save(struct admin* h) {

    FILE* fp = fopen("admin_text.text", "w");

    if (!fp) { printf("管理员文件保存失败\n"); return; }

    for (struct admin* p = h; p; p = p->next)

        fprintf(fp, "%s %s\n", p->username, p->password);

    fclose(fp);

}


void admin_free(struct admin* h) {

    while (h) { struct admin* t = h; h = h->next; free(t); }

}


