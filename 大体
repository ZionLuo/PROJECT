    }

    printf("订单 %d 已完成\n", id);

}

struct order* order_place(struct order* ohead, struct user* u,

    struct business* bhead, struct rider* rhead)

{

    if (!bhead) { printf("暂无商家\n"); return ohead; }

    printf("\n--- 商家 ---\n");

    for (struct business* b = bhead; b; b = b->next)

        printf("%d\t%s\t%s\n", b->id, b->name, b->location);

    int bid; printf("选商家编号："); scanf("%d", &bid);

    struct business* b = business_search(bhead, bid);

    if (!b) { printf("商家不存在\n"); return ohead; }


    printf("--- %s 菜单 ---\n", b->name);

    for (int i = 0; i < b->dish_count; i++)

        printf("%d. %s %d元\n", i + 1, b->menu[i], b->price[i]);

    int ch; printf("点菜编号："); scanf("%d", &ch);

    if (ch < 1 || ch > b->dish_count) { printf("无效选择\n"); return ohead; }

    ch--;


    struct order* p = (struct order*)malloc(sizeof(struct order));

    if (!p) return ohead;

    printf("订单编号："); scanf("%d", &p->id);

    for (struct order* q = ohead; q; q = q->next)

        if (q->id == p->id) { printf("订单编号已存在\n"); free(p); return ohead; }


    strcpy(p->dish, b->menu[ch]);

    p->price = b->price[ch];

    p->business_id = b->id;

    p->rider_id = -1;

    strcpy(p->user, u->username);

    strcpy(p->sp, b->location);

    strcpy(p->ep, u->address);

    strcpy(p->route, "无路径");

    p->distance = -1;

    p->finished = 0;

    p->next = NULL;


    int d = -1; char path[200];

    if (map_dijkstra(&g_map, p->sp, p->ep, path, sizeof(path), &d) == 0) {

        strcpy(p->route, path); p->distance = d;

        printf("配送路径：%s  距离 %d km\n", path, d);

    }
    else {

        printf("地图无路径 [%s] -> [%s]，请管理员补充路线后再下单\n", p->sp, p->ep);

    }


    if (!ohead) ohead = p;

    else { struct order* r = ohead; while (r->next) r = r->next; r->next = p; }


    int rid = dispatch(p, rhead);

    if (rid >= 0) printf("已派单骑手 #%d\n", rid);

    else         printf("暂无可用骑手\n");


    printf("下单成功 订单编号 %d\n", p->id);

    return ohead;

}

int dispatch(struct order* o, struct rider* rhead) {

    if (!rhead) return -1;

    struct rider* pick = NULL;

    /* 优先：同区域 + 闲 */

    for (struct rider* r = rhead; r; r = r->next)

        if (r->busy == 0 && strcmp(r->area, o->ep) == 0)

            if (!pick || r->task_count < pick->task_count) pick = r;

    /* 次选：任意闲 */

    if (!pick)

        for (struct rider* r = rhead; r; r = r->next)

            if (r->busy == 0)

                if (!pick || r->task_count < pick->task_count) pick = r;

    if (!pick) return -1;

    pick->busy = 1; pick->task_count++;

    o->rider_id = pick->id;

    return pick->id;

}
